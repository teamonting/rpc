{
  "name": "@onting/root",
  "version": "0.1.0-0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "@onting/root",
      "version": "0.1.0-0",
      "workspaces": [
        "packages/rpc",
        "packages/pages",
        "packages/integration-test"
      ]
    },
    "node_modules/@onting/rpc": {
      "resolved": "packages/rpc",
      "link": true
    },
    "node_modules/@onting/integration-test": {
      "resolved": "packages/integration-test",
      "link": true
    },
    "node_modules/@onting/pages": {
      "resolved": "packages/pages",
      "link": true
    },
    "packages/integration-test": {
      "name": "@onting/integration-test",
      "version": "0.0.0-0",
      "license": "MIT",
      "devDependencies": {
        "$package-name": "^0.0.0-0"
      }
    },
    "packages/pages": {
      "name": "@onting/pages",
      "version": "0.0.0-0",
      "license": "MIT",
      "devDependencies": {
        "$package-name": "^0.0.0-0"
      }
    },
    "packages/rpc": {
      "name": "@onting/rpc",
      "version": "0.0.0-0",
      "license": "MIT",
      "devDependencies": {}
    }
  }
}
